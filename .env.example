DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_ALLOWED_USER_IDS=123456789012345678
SOCIAL_DESK_ROOT=/home/brandon/social-desk
SOCIAL_DESK_NOTIFY_ENABLED=true
SOCIAL_DESK_NOTIFY_INTERVAL_MS=300000
# SOCIAL_DESK_DAILY_SUMMARY_HOUR_UTC=15
DISCORD_PROGRESS_NOTIFY_ENABLED=true
DISCORD_PROGRESS_NOTIFY_INTERVAL_MS=15000
DISCORD_PROGRESS_NOTIFY_LEVELS=milestone,blocker,complete
# DISCORD_PROGRESS_EVENTS_PATH=/home/brandon/discord-bridge/runtime/progress-events.jsonl

DISCORD_REPLY_BACKEND=codex

CODEX_BIN=codex
CODEX_CWD=..
CODEX_MODEL=gpt-5.4
CODEX_TIMEOUT_MS=180000
CODEX_STREAM_JSON=true
CODEX_REASONING_EFFORT=low
CODEX_NETWORK_ACCESS_ENABLED=true
CODEX_USE_OPENAI_API_KEY=false
# CODEX_SDK_MODULE_PATH=/absolute/path/to/@openai/codex-sdk/dist/index.js

# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.4
# OPENAI_SYSTEM_PROMPT=You are Forge, a private AI operations assistant.
